# Additional local input for scripts/render-local-compose.mjs.
# Copy to .env.langfuse, fill real values, and keep mode 0600.

# NEXTAUTH_URL defaults to http://<container-host-ip>:3001 during rendering.
# Override only when Langfuse is exposed through a stable domain or proxy.
# NEXTAUTH_URL=https://langfuse.example.com

# Generate independent URL/shell-safe values:
#   openssl rand -hex 32
NEXTAUTH_SECRET=change-me
SALT=change-me
REDIS_AUTH=change-me
LANGFUSE_POSTGRES_PASSWORD=change-me
MINIO_ROOT_PASSWORD=change-me
CLICKHOUSE_PASSWORD=change-me

# Must be 64 hexadecimal characters:
#   openssl rand -hex 32
ENCRYPTION_KEY=change-me

# The same pair initializes the Langfuse project and authenticates Samata SDK
# ingestion into the fresh production project.
LANGFUSE_PUBLIC_KEY=pk-lf-samata-change-me
LANGFUSE_SECRET_KEY=sk-lf-samata-change-me

# Organization/project/admin identity is fixed in Compose; only the initial
# administrator password remains deployment-specific.
LANGFUSE_INIT_USER_PASSWORD=change-me
