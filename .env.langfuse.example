# Copy to .env.langfuse for local-only Langfuse Docker deployment.
# Keep .env.langfuse out of git; it contains project API keys and service secrets.

NEXTAUTH_URL=http://127.0.0.1:3001
LANGFUSE_BIND_ADDRESS=127.0.0.1
LANGFUSE_WEB_PORT=3001
LANGFUSE_MINIO_PORT=9090
LANGFUSE_MINIO_CONSOLE_PORT=9091

# Optional: override images for private registry deployment.
# LANGFUSE_WEB_IMAGE=dockertest.gf.com.cn/titans/otcclaw-langfuse:3
# LANGFUSE_WORKER_IMAGE=dockertest.gf.com.cn/titans/otcclaw-langfuse-worker:3
# LANGFUSE_CLICKHOUSE_IMAGE=dockertest.gf.com.cn/titans/otcclaw-langfuse-clickhouse-server:latest
# LANGFUSE_MINIO_IMAGE=dockertest.gf.com.cn/titans/otcclaw-langfuse-minio:latest
# LANGFUSE_REDIS_IMAGE=dockertest.gf.com.cn/titans/otcclaw-langfuse-redis:7
# LANGFUSE_POSTGRES_IMAGE=dockertest.gf.com.cn/titans/otcclaw-langfuse-postgres:16

# Generate unique values before use:
#   openssl rand -base64 32
NEXTAUTH_SECRET=change-me
SALT=change-me
REDIS_AUTH=change-me
LANGFUSE_POSTGRES_PASSWORD=change-me
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me

# Must be 64 hex characters:
#   openssl rand -hex 32
ENCRYPTION_KEY=change-me

# Samata will use the same public/secret key pair.
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-samata-local-change-me
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-samata-local-change-me

LANGFUSE_INIT_ORG_ID=samata
LANGFUSE_INIT_ORG_NAME=Samata
LANGFUSE_INIT_PROJECT_ID=samata-local
LANGFUSE_INIT_PROJECT_NAME=Samata Local
LANGFUSE_INIT_USER_EMAIL=admin@samata.local
LANGFUSE_INIT_USER_NAME=Samata Admin
LANGFUSE_INIT_USER_PASSWORD=change-me
