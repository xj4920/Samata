# 方式1: 直接使用 Anthropic API
ANTHROPIC_API_KEY=your-api-key-here

# 方式2: 使用自定义网关 (如 Claude CLI 配置)
# ANTHROPIC_AUTH_TOKEN=sk-xxx
# ANTHROPIC_BASE_URL=https://your-gateway.com

# MiniMax 配置
# MINIMAX_API_KEY=your-minimax-key
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_MODEL=MiniMax-Text-01

# Gemini 配置（默认从 ~/.gemini/.env 读取，也可在此覆盖）
# GEMINI_API_KEY=your-gemini-key
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_MODEL=gemini-2.0-flash

# OpenRouter 配置（通过一个 API key 访问多种模型）
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Custom OpenAI-compatible 配置
# CUSTOM_API_KEY=your-custom-key
# CUSTOM_BASE_URL=https://api.openai.com/v1
# CUSTOM_MODEL=custom-model
# CUSTOM_VISION_MODEL=custom-vision-model
# CUSTOM_MODELS=custom-model,custom-vision-model

# LLM Provider 选择 (anthropic | minimax | gemini | openrouter | custom | deepseek)，默认 anthropic
# LLM_PROVIDER=anthropic
# LLM_MODEL=                # 可选，覆盖默认模型名
# SHOW_THINKING=true        # 是否显示 AI 思考过程和工具调用日志，默认 true
# MAX_TOOL_ROUNDS=30        # 单次对话内 agentic loop 的工具调用轮次上限，默认 30

# Langfuse agentchat 只读观测（默认关闭；不使用 Langfuse Prompt Management）
# LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_TRACING_ENVIRONMENT=production
# LANGFUSE_CAPTURE_CONTENT=false        # 默认只发结构化元数据/token/耗时，不上传对话与工具正文
# LANGFUSE_CAPTURE_SYSTEM_PROMPT=false  # 仅在 CAPTURE_CONTENT=true 时可选择上传 system prompt
# LANGFUSE_EXPORT_MODE=batched          # batched | immediate

# Dream 每日回顾分析专用 provider/model（独立于全局 LLM_PROVIDER）
# 建议指向便宜稳定的 provider，避免因主 provider 余额不足导致 dream 生成失败
# DREAM_PROVIDER=deepseek
# DREAM_MODEL=deepseek-v4-flash

# Wiki 编译并发数（默认 3）
# WIKI_COMPILE_CONCURRENCY=3
# Wiki 短文档使用快速模型（可选，未设则全用 DREAM provider）
# WIKI_FAST_PROVIDER=gemini
# WIKI_FAST_MODEL=gemini-2.0-flash
# WIKI_FAST_THRESHOLD=2000

# Plugin 目录（逗号分隔多个目录，默认 ../samata-plugins）
# SAMATA_PLUGINS_DIR=../samata-plugins,../samata-plugin-work

# PostgreSQL Wind 数据 (本地 Docker)
PG_WIND_HOST=127.0.0.1
PG_WIND_PORT=5432
PG_WIND_USER=wind_sync
PG_WIND_PASS=wind_sync
PG_WIND_DATABASE=wind_sync

# SBL data plugin
SBL_SFTP_HOST=10.68.15.21
SBL_SFTP_PORT=22
SBL_SFTP_USER=EQDHK_internal
SBL_SFTP_PASSWD=your-sbl-sftp-password
SBL_SFTP_REMOTE_BASE=/EQDHK_internal/data/SBL

# 常速 summary plugin
NORMAL_TRADING_SFTP_HOST=10.68.15.21
NORMAL_TRADING_SFTP_PORT=22
NORMAL_TRADING_SFTP_USER=EQDHK_internal
NORMAL_TRADING_SFTP_PASSWORD=your-normal-trading-sftp-password
NORMAL_TRADING_SFTP_REMOTE_BASE=/EQDHK_internal/data/NormalTrading/summary

# 极速 FastTrading summary plugin
FAST_TRADING_SFTP_HOST=10.68.15.21
FAST_TRADING_SFTP_PORT=22
FAST_TRADING_SFTP_USER=EQDHK_internal
FAST_TRADING_SFTP_PASSWORD=your-fast-trading-sftp-password
FAST_TRADING_SFTP_REMOTE_BASE=/EQDHK_internal/data/FastTrading/summary
FAST_TRADING_PG_HOST=127.0.0.1
FAST_TRADING_PG_PORT=5432
FAST_TRADING_PG_USER=wind_sync
FAST_TRADING_PG_PASSWORD=wind_sync
FAST_TRADING_PG_DATABASE=samata

# Hedge ratio plugin secrets (config/hedge-ratio.json only keeps non-secret business settings)
HEDGE_RATIO_EMAIL_ADDRESS=titans@example.com
HEDGE_RATIO_EMAIL_PASSWORD=your-email-password
HEDGE_RATIO_EMAIL_IMAP_SERVER=mail.example.com
HEDGE_RATIO_EMAIL_IMAP_PORT=993
HEDGE_RATIO_SFTP_ENABLED=true
HEDGE_RATIO_SFTP_HOST=sftp.example.com
HEDGE_RATIO_SFTP_PORT=22
HEDGE_RATIO_SFTP_USERNAME=your-sftp-user
HEDGE_RATIO_SFTP_PASSWORD=your-sftp-password
HEDGE_RATIO_SFTP_REMOTE_BASE_PATH=/data/QFII

WIND_PG_HOST=127.0.0.1
WIND_PG_PORT=5432
WIND_PG_DATABASE=wind_sync
WIND_PG_USER=wind_sync
WIND_PG_PASSWORD=your-wind-pg-password

# Serper.dev (Google search API, used by web_search tool)
# SERPER_API_KEY=your_serper_api_key
