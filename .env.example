# 方式1: 直接使用 Anthropic API
ANTHROPIC_API_KEY=your-api-key-here

# 方式2: 使用自定义网关 (如 Claude CLI 配置)
# ANTHROPIC_AUTH_TOKEN=sk-xxx
# ANTHROPIC_BASE_URL=https://your-gateway.com

# MiniMax 配置
# MINIMAX_API_KEY=your-minimax-key
# MINIMAX_BASE_URL=https://api.minimax.chat/v1
# MINIMAX_MODEL=MiniMax-Text-01

# LLM Provider 选择 (anthropic | minimax)，默认 anthropic
# LLM_PROVIDER=anthropic
# LLM_MODEL=                # 可选，覆盖默认模型名
# SHOW_THINKING=true        # 是否显示 AI 思考过程和工具调用日志，默认 true

# InfluxDB 配置 (只读查询)
INFLUX_HOST=175.178.64.67
INFLUX_PORT=8181
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_DATABASE=otchk
INFLUX_TIMEOUT=60
