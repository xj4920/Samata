# Local input for scripts/render-local-compose.mjs.
# This file is never mounted into a container. Copy it to .env, fill real
# values, keep mode 0600, and render /opt/samata/docker-compose.yml.

# Private registry root and OtcClaw image tag.
DOCKER_REPO=dockertest.gf.com.cn
IMAGE_VERSION=v3.0.34-example

# Custom OpenAI-compatible provider used by production.
CUSTOM_API_KEY=change-me
CUSTOM_BASE_URL=https://api.example.com/v1
CUSTOM_MODEL=external-deepseek-v4-pro
CUSTOM_VISION_MODEL=vision-model

# Web search.
SERPER_API_KEY=change-me

# Dedicated Samata database in the Langfuse PostgreSQL instance.
# User/database are fixed to samata_app/samata. Do not reuse the Langfuse
# database password. Generate a URL/shell-safe value, for example:
#   openssl rand -hex 32
SAMATA_POSTGRES_PASSWORD=change-me

# Every production plugin shares this host, user and password. Port 22 and the
# eight business remote paths remain fixed in Compose.
SFTP_HOST=10.68.15.21
SFTP_USER=EQDHK_internal
SFTP_PASSWORD=change-me

# Hedge Ratio mailbox remains environment-specific and must be filled.
HEDGE_RATIO_EMAIL_ADDRESS=titans@example.com
HEDGE_RATIO_EMAIL_PASSWORD=change-me
HEDGE_RATIO_EMAIL_IMAP_SERVER=mail.example.com
HEDGE_RATIO_EMAIL_IMAP_PORT=993

# Both production LogYi MCP instances share the fixed base URL/username and
# this one API key. Compose maps it to their existing compatibility variables.
LOGYI_API_KEY=change-me
