{
  "name": "Samata",
  "version": "3.0.13",
  "description": "Samata",
  "main": "src/index.ts",
  "scripts": {
    "start": "bash scripts/start.sh",
    "dev": "tsx watch src/index.ts",
    "stop": "pkill -f 'tsx src/index.ts' ; pkill -f 'tsx src/cli/index.ts' ; true",
    "server": "npm run stop && tsx src/index.ts --server",
    "cli": "tsx src/cli/index.ts",
    "telegram": "npx tsx src/telegram-entry.ts",
    "wework": "npx tsx src/wework-entry.ts",
    "check-readme": "npx tsx scripts/check-readme.ts",
    "analyze-log": "npx tsx scripts/analyze-log.ts",
    "docs:plan-sync": "tsx scripts/sync-docs-plan-index.ts",
    "docs:plan-watch": "tsx scripts/sync-docs-plan-index.ts --watch",
    "docs:dev": "npm run docs:plan-sync && vitepress dev docs",
    "docs:build": "npm run docs:plan-sync && vitepress build docs",
    "docs:check": "npm run docs:plan-sync -- --check && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "test": "bash scripts/test.sh",
    "test:unit": "bash scripts/test.sh",
    "test:e2e": "bash scripts/test.sh --config vitest.e2e.config.ts",
    "test:watch": "bash scripts/test.sh --watch"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@inquirer/prompts": "^8.3.0",
    "@langfuse/otel": "^5.4.1",
    "@langfuse/tracing": "^5.4.1",
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "@types/turndown": "^5.0.6",
    "@wecom/aibot-node-sdk": "^1.0.6",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "cli-table3": "^0.6.5",
    "cron-parser": "^5.5.0",
    "dayjs": "^1.11.20",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.5.8",
    "https-proxy-agent": "^7.0.6",
    "pino": "^10.3.1",
    "puppeteer": "^24.40.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "undici": "^7.22.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "@types/uuid": "^10.0.0",
    "chrome-devtools-mcp": "^0.2.6",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.7",
    "yaml": "^2.8.2"
  }
}
